generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  senha    String
  tarefas  Tarefa[]
}

model Tarefa {
  id         Int      @id @default(autoincrement())
  titulo     String
  concluida  Boolean  @default(false)
  usuarioId  Int
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
}